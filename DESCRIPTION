Package: CMEnt
Type: Package
Title: Characterization of Methylation using positional ENTanglement
Version: 0.99.0
Authors@R: c(
    person(given   = "Vasileios",
           family  = "Lemonidis",
           role    = c("aut", "cre", "cph"),
           email   = "vasileios.lemonidis@uantwerpen.be",
           comment = c(ORCID = "0000-0002-6446-3536")),
